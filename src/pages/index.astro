---
import Layout from "../layouts/Layout.astro";
import { skills } from "../data/skills";
import Button from "../ui/button.astro";
import SkillCard from "../ui/skill-card.astro";

const MAX_SKILLS = 12;

const displayedSkills = [...skills]
  .sort((a, b) => {
    const aIsMine = (a.sourceKey ?? "") === "ibelick";
    const bIsMine = (b.sourceKey ?? "") === "ibelick";

    if (aIsMine && !bIsMine) return -1;
    if (!aIsMine && bIsMine) return 1;

    return a.pathSlug.localeCompare(b.pathSlug);
  })
  .slice(0, MAX_SKILLS)
  .map((skill) => {
    const owner = skill.sourceKey ?? "ibelick";

    return {
      ...skill,
      owner,
      ownerLabel: skill.sourceLabel ?? "Ibelick",
      avatarUrl: `https://github.com/${owner}.png?size=40`,
    };
  });
---

<Layout>
  <div
    class="relative flex min-h-dvh flex-col items-center justify-end px-0 sm:px-4"
  >
    <div class="relative mt-20 w-full max-w-3xl sm:px-0">
      <div class="mx-auto flex w-full flex-col gap-14">
        <div class="px-4 sm:px-0">
          <h1 class="text-parchment-900 text-3xl font-medium tracking-tight">
            UI Skills
          </h1>
          <p class="text-parchment-600 mt-3 text-lg">
            Skills for Design Engineers
          </p>
        </div>

        <div>
          <h2
            class="text-parchment-900 mb-4 px-4 text-lg font-medium tracking-tight sm:px-0"
          >
            Skills
          </h2>
          <div class="grid gap-4 px-4 sm:grid-cols-2 sm:px-0">
            {
              displayedSkills.map((skill) => (
                <SkillCard
                  href={`/skills/${skill.pathSlug}`}
                  slug={skill.slug}
                  description={skill.description}
                  ownerLabel={skill.ownerLabel}
                  avatarUrl={skill.avatarUrl}
                />
              ))
            }
          </div>
          <div class="mt-4 flex justify-center px-4 sm:px-0">
            <Button href="/skills">
              See all skills
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
